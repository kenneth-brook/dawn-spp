          <div class="ingredBox">
            <div class="instructHead">
              <h6>Ingredients</h6>
            </div>
            
            <ul>
              <li>4 tablespoons melted butter</li>
              <li>2 teaspoons salt of your choice</li>
              <li>2 teaspoons Worcestershire sauce</li>
              <li>4 cups of pecan halves</li>
            </ul>
          </div>
        </div>
        <div class="instruct">
          <div class="instructHead">
            <h6>Directions:</h6>
          </div>
          <div class="lineWrap">
            <div class="numb">
              <p>1</p>
            </div>
            <div class="line">
              <p>Preheat oven to 300 degrees</p>
            </div>
          </div>
          <div class="lineWrap">
            <div class="numb">
              <p>2</p>
            </div>
            <div class="line">
              <p>Combine all ingredients</p>
            </div>
          </div>
          <div class="lineWrap">
            <div class="numb">
              <p>3</p>
            </div>
            <div class="line">
              <p>Make sure Pecans are coated well</p>
            </div>
          </div>
          <div class="lineWrap">
            <div class="numb">
              <p>4</p>
            </div>
            <div class="line">
              <p>Spread in a single layer in a baking pan.</p>
            </div>
          </div>
          <div class="lineWrap">
            <div class="numb">
              <p>5</p>
            </div>
            <div class="line">
              <p>Bake for 10 minutes</p>
            </div>
          </div>
          <div class="lineWrap">
            <div class="numb">
              <p>6</p>
            </div>
            <div class="line">
              <p>Stir and return to bake 10-15 minutes</p>
            </div>
          </div>
          <div class="lineWrap">
            <div class="numb">
              <p>7</p>
            </div>
            <div class="line">
              <p>Remove from oven when they are golden brown.</p>
            </div>
          </div>
          
          
        </div>
        </div>
