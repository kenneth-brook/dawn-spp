<style>
  .footerWrap {
    padding-top: 10px;
    width: 100%;
    min-height: 75px;
    position: relative;
    top: 50px;
  }

  .footerTop {
    border-top: 2px solid #555555;
    border-bottom: 2px solid #555555;
    padding: 20px 45px;
    display: flex;
    justify-content: space-between;
  }

  .footerTop img {
    width: 20%;
    object-fit: contain;
  }

  .contactBox {
    width: 20%;
    background-color: #EBF8CE;
    border-radius: 10px;
    padding: 35px 50px;
  }

  .contactBox p {
    font-size: 1.8rem;
    font-weight: bold;
    text-align: center;
  }

  .conBut {
    margin: 0 auto;
    margin-top: 15px;
    width: fit-content;
    border-radius: 10px;
    background-color: #78B000;
    box-shadow: 5px 5px 10px #00000055;
  }

  .conBut a {
    font-size: 2.2rem;
    font-weight: bold;
    text-align: center;
    color: white;
    padding: 15px 20px
  }

  .textTop {
    width: 55%;
  }

  .textTop h4 {
    font-size: 3.2rem;
    color: #6F573F;
  }

  .textTop p {
    font-size: 1.8rem;
  }

  .textTop p span {
    color: #78B000;
    font-weight: bold;
  }

  .footerBottom {
    width: 75%;
    margin: 0 auto;
    display: flex;
    padding: 25px 0;
    justify-content: space-between;
    align-items: center;
  }

  .contactWrap {
    display: flex;
    flex-direction: column;
  }

  .contactLine {
    display: flex;
    color: black;
  }

  .contactLine a {
    display: flex;
    text-decoration: none;
    color: black;
  }

  .contactLine img {
    object-fit: contain;
  }

  .contactLine p {
    margin-left: 15px;
  }

  .footIcos {
    display: flex;
  }

  .footIcos a {
    width: 30px;
    height: 30px;
    margin: 0 15px;
    
  }

  .footIcos img {
    object-fit: contain;
    width: 30px;
    height: 30px;
  }

  .footVBottom {
    background-color: black;
    height: 75px;
    width: 100%;
    display: flex;
    justify-content: space-around;
    align-items: center;
    padding: 20px 75px;
  }

  .footVBottom p {
    color: white;
  }

  @media screen and (max-width: 1368px) {
    .contactBox {
      padding: 15px;
    }
  }

  @media screen and (max-width: 1200px) {
    .footerTop {
      flex-direction: column;
    }

    .footerTop img, .textTop, .contactBox {
      width: 100%;
    }

    .footerBottom {
      flex-direction: column;
    }

    .footVBottom {
      flex-direction: column;
      height: auto;
    }
  }

  #shopify-section-sections--20710880084284__footer {
    position: relative;
    top: -50px;
  }
</style>

