<div class="headWrap">
  <div class="headTop"><h1></h1></div>
  <div class="headBottom"><h1></h1></div>
</div>


<style>
  .headWrap {
    width: 100%;
    background-color: #FFFFFF;
  }

  .headTop {
    background: url("https://cdn.shopify.com/s/files/1/0816/7306/0668/files/spptophead.jpg");
    background-size: cover;
    width: 100%;
    min-height: 90px;
    position: relative;
    top: 0;
  }

  .headBottom {
    background-color: #78B000;
    width: 100%;
    min-height: 90px;
    position: relative;
    top: 10px;
  }

  .headTop h1, .headBottom h1 {
    margin-top: 0;
  }
</style>


{% schema %}
{
  "name": "t:sections.image-banner.name",
  "tag": "section",
  "class": "section",
  
  "blocks": [
    {
      "type": "heading",
      "name": "t:sections.image-banner.blocks.heading.name",
      "limit": 1,
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Image banner",
          "label": "t:sections.image-banner.blocks.heading.settings.heading.label"
        },
        {
          "type": "select",
          "id": "heading_size",
          "options": [
            {
              "value": "h2",
              "label": "t:sections.all.heading_size.options__1.label"
            },
            {
              "value": "h1",
              "label": "t:sections.all.heading_size.options__2.label"
            },
            {
              "value": "h0",
              "label": "t:sections.all.heading_size.options__3.label"
            }
          ],
          "default": "h1",
          "label": "t:sections.all.heading_size.label"
        }
      ]
    }
  ]
  
}
{% endschema %}

{% stylesheet %}
{% endstylesheet %}

